SERPAPI_KEY=your_key_here
# API port. Vite client runs on 4811 and proxies /api here. Same on Mac + Windows.
PORT=4810

# Optional Apify scraper source — powers the "scrape" sources.
# Get a token at https://console.apify.com/account/integrations
APIFY_TOKEN=
# Which Actor to run (default: Google Shopping Scraper).
# e.g. apify/google-shopping-scraper  — swap for a McMaster/Parts Town actor if you have one.
APIFY_ACTOR=apify/google-shopping-scraper
# The input key this actor uses for the search term (Google Shopping Scraper uses "queries").
APIFY_QUERY_KEY=queries
# Optional extra actor input as JSON, merged into the run (e.g. {"country":"us"}).
APIFY_INPUT_JSON=

# Optional BigQuery inventory source
BIGQUERY_PROJECT=your_gcp_project
BIGQUERY_DATASET=parts_dataset
BIGQUERY_TABLE=parts_table
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Optional column overrides
BIGQUERY_TITLE_COLUMN=title
BIGQUERY_SOURCE_COLUMN=source
BIGQUERY_PRICE_COLUMN=price
BIGQUERY_SHIPPING_COLUMN=shipping
BIGQUERY_CONDITION_COLUMN=condition
BIGQUERY_LINK_COLUMN=link
BIGQUERY_THUMBNAIL_COLUMN=thumbnail
BIGQUERY_SEARCH_COLUMN=search_text
