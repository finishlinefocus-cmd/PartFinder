{
  "name": "partfinder-server",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "dev:api": "node server.js",
    "dev:client": "npm --prefix client run dev",
    "dev:all": "node scripts/launch-dev.mjs",
    "launch": "npm run dev:all",
    "autostart:install": "node scripts/autostart.mjs install",
    "autostart:uninstall": "node scripts/autostart.mjs uninstall",
    "autostart:status": "node scripts/autostart.mjs status"
  },
  "dependencies": {
    "@google-cloud/bigquery": "^8.1.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "node-fetch": "^3.3.2"
  }
}
